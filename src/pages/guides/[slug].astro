---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import HoustonRegionMap from '../../components/HoustonRegionMap.astro';
import SourcePanel from '../../components/SourcePanel.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => data.status === 'published');
  return guides.map((guide) => ({
    params: { slug: guide.data.slug },
    props: { guide },
  }));
}

interface Props {
  guide: Awaited<ReturnType<typeof getCollection<'guides'>>>[number];
}

const { guide } = Astro.props;
const { data } = guide;
const { Content } = await render(guide);
---

<Base
  title={`${data.title} — Houston, Handled.`}
  description={data.description}
  pageType="article"
  updatedAt={data.updatedAt}
  breadcrumbs={[
    { name: 'Houston, Handled.', path: '/houston/' },
    { name: 'Guides', path: '/houston/guides' },
    { name: data.title, path: `/houston/guides/${data.slug}` },
  ]}
>
  <main class="container article-page" data-track-view="houston_guide_view" data-track-slug={data.slug}>
    <header class="article-header">
      <p class="mono-label mono-label--red">Houston in real life</p>
      <h1>{data.title}</h1>
      <p class="description">{data.description}</p>
    </header>

    <article class="article-body">
      {data.slug === 'how-houston-is-organized' && <HoustonRegionMap />}
      <Content />
    </article>

    <section class="disclaimers" aria-label="Important notices">
      {data.disclaimerIds.map((id) => <Disclaimer id={id} />)}
    </section>

    <SourcePanel sources={data.sources} updatedAt={data.updatedAt} />
  </main>
</Base>

<style>
  .article-page {
    max-width: 900px;
    padding-top: var(--space-block);
    padding-bottom: var(--space-section);
  }

  .article-header {
    display: grid;
    gap: 18px;
    max-width: 760px;
    margin-bottom: var(--space-block);
  }

  h1 {
    font-family: var(--display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .description {
    color: var(--mid);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    max-width: 60ch;
  }

  .article-body {
    max-width: 68ch;
  }

  .article-body :global(h2) {
    font-family: var(--display);
    font-size: var(--fs-h3);
    line-height: 1.18;
    margin: 2.75em 0 0.75em;
  }

  .article-body :global(h3) {
    font-family: var(--display);
    font-size: 1.1rem;
    margin: 2em 0 0.65em;
  }

  .article-body :global(p),
  .article-body :global(li) {
    line-height: 1.75;
  }

  .article-body :global(p + p),
  .article-body :global(ul),
  .article-body :global(ol) {
    margin-top: 1.1em;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.4em;
  }

  .article-body :global(a) {
    color: var(--red-text);
    text-underline-offset: 3px;
  }

  .disclaimers {
    margin-top: var(--space-block);
    display: grid;
    gap: 16px;
    max-width: 68ch;
  }
</style>
