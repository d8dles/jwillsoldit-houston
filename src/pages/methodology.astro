---
import Base from '../layouts/Base.astro';
import Disclaimer from '../components/Disclaimer.astro';
import SourcePanel from '../components/SourcePanel.astro';
import type { DisclaimerId } from '../data/disclaimers';

const disclaimerIds: DisclaimerId[] = [
  'general',
  'schools',
  'flood',
  'travel-times',
  'development',
  'market',
];

const correctionsHref =
  'mailto:jwillsoldit@icloud.com?subject=' +
  encodeURIComponent('Houston, Handled. correction');

const updatedAt = '2026-07-18';
const sources = [
  {
    label: 'Houston, Handled. Phase 1 Specification',
    accessed: updatedAt,
  },
  {
    label: 'Texas Real Estate Commission — public information and required notices',
    url: 'https://www.trec.texas.gov/public-information-0',
    accessed: updatedAt,
  },
  {
    label: 'U.S. Department of Housing and Urban Development — Fair Housing Act overview',
    url: 'https://www.hud.gov/helping-americans/fair-housing-act-overview',
    accessed: updatedAt,
  },
];
---

<Base
  title="Methodology — Houston, Handled."
  description="How Houston, Handled. sources and verifies its information, what Greater Houston means on this site, and where its limits are."
  pageType="real-estate-agent"
  updatedAt={updatedAt}
>
  <main class="container methodology">
    <header class="page-header">
      <p class="mono-label">Methodology</p>
      <h1>How this site is built</h1>
      <p class="intro">
        I run Houston, Handled. myself. This page explains where the
        information comes from, what "Greater Houston" means here, and what
        this site does not do yet.
      </p>
    </header>

    <section class="block">
      <h2>How I source content</h2>
      <p>
        I work through sources in a fixed order and prefer the highest tier
        available for each fact.
      </p>
      <ol class="tier-list">
        <li>
          <strong>Government and public agencies.</strong> County appraisal
          districts, cities, school districts, FEMA, and other public bodies
          come first.
        </li>
        <li>
          <strong>Authorized MLS or official business sources.</strong> MLS
          data I am licensed to use, and official statements from businesses
          or developers, come next.
        </li>
        <li>
          <strong>Reputable local reporting.</strong> Houston-area news
          outlets fill gaps the sources above do not cover.
        </li>
        <li>
          <strong>Verified local notes.</strong> Anything I add from direct,
          personal knowledge of an area is labeled as a note, not a fact from
          a public source.
        </li>
      </ol>
      <p>
        Every region, guide, and area page links its sources and the date I accessed
        them, plus the date the page was last reviewed.
      </p>
    </section>

    <section class="block">
      <h2>What "Greater Houston" means here</h2>
      <p>
        On this site, "Greater Houston" means the city of Houston plus the
        surrounding counties people commonly commute from. It is not the
        official U.S. Census Metropolitan Statistical Area boundary, and I do
        not claim it is. Maps and region groupings on this site are
        schematic — built to orient a reader, not to serve as a legal or
        official reference.
      </p>
    </section>

    <section class="block">
      <h2>Known limitations</h2>
      <ul class="limits-list">
        <li>
          This site does not include market pricing data yet. Nothing here
          should be read as a valuation or a price estimate.
        </li>
        <li>
          Maps are schematic. They are meant to show general position and
          relationships between places, not to serve as survey-grade
          boundaries.
        </li>
        <li>
          Content is dated. Every page shows the date it was last reviewed.
          If that date is old, verify independently before relying on it.
        </li>
      </ul>
    </section>

    <section class="block">
      <h2>Disclaimers</h2>
      <div class="disclaimer-list">
        {disclaimerIds.map((id) => <Disclaimer id={id} />)}
      </div>
    </section>

    <section class="block">
      <h2>Corrections</h2>
      <p>
        If something on this site is wrong or out of date, tell me and I
        will fix it. Email
        {' '}
        <a href={correctionsHref}>jwillsoldit@icloud.com</a>
        {' '}
        with the subject line "Houston, Handled. correction."
      </p>
    </section>

    <SourcePanel sources={sources} updatedAt={updatedAt} />
  </main>
</Base>

<style>
  .methodology {
    padding-top: var(--space-block);
    padding-bottom: var(--space-section);
    max-width: 760px;
  }

  .page-header {
    margin-bottom: var(--space-block);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  h1 {
    font-family: var(--display);
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .intro {
    font-size: var(--fs-body);
    color: var(--mid);
    max-width: 60ch;
  }

  .block {
    margin-bottom: var(--space-block);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  h2 {
    font-family: var(--display);
    font-size: var(--fs-h3);
    font-weight: 600;
    color: var(--ink);
  }

  .block p,
  .tier-list,
  .limits-list {
    color: var(--ink);
    line-height: 1.7;
    max-width: 65ch;
  }

  .tier-list,
  .limits-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-left: 1.25em;
  }

  .disclaimer-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  a {
    color: var(--red-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
