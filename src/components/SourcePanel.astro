---
interface Source {
  label: string;
  url?: string;
  accessed: string;
}

interface Props {
  sources: Source[];
  updatedAt: string;
}

const { sources, updatedAt } = Astro.props;
const formatDate = (value: string) => new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
}).format(new Date(`${value}T00:00:00Z`));
---

<details class="source-panel">
  <summary class="mono-label">Sources and review date</summary>
  <div class="source-panel-body">
    <ul class="source-list">
      {sources.map((source) => (
        <li>
          <div class="source-entry">
            {source.url ? (
              <a href={source.url} rel="noopener" target="_blank">{source.label}</a>
            ) : (
              <span>{source.label}</span>
            )}
            <span class="accessed">Source checked {formatDate(source.accessed)}</span>
          </div>
        </li>
      ))}
    </ul>
    <p class="reviewed-line">Page information last reviewed {formatDate(updatedAt)}</p>
  </div>
</details>

<style>
  .source-panel {
    border-top: 1px solid var(--trace);
    border-bottom: 1px solid var(--trace);
    padding: 20px 0;
    margin: var(--space-block) 0;
  }

  summary {
    cursor: pointer;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  summary::marker {
    color: var(--mid);
  }

  .source-panel-body {
    padding-top: 16px;
  }

  .source-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .source-list li {
    font-size: var(--fs-small);
  }

  .source-entry {
    display: grid;
    gap: 2px;
  }

  .source-list a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--trace);
    text-underline-offset: 3px;
  }

  .source-list a:hover {
    color: var(--red-text);
  }

  .accessed {
    font-family: var(--mono);
    font-size: var(--fs-micro);
    color: var(--mid);
  }

  .reviewed-line {
    margin-top: 18px;
    padding-top: 12px;
    border-top: 1px solid var(--trace);
    font-family: var(--mono);
    font-size: var(--fs-micro);
    color: var(--mid);
  }
</style>
