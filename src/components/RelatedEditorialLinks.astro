---
interface LinkItem {
  kind: 'area' | 'region' | 'guide';
  label: string;
  href: string;
}

interface Props {
  links: LinkItem[];
  heading: string;
}

const { links, heading } = Astro.props;
const kindLabels = { area: 'Area', region: 'Region', guide: 'Guide' };
---

{links.length > 0 && (
  <section class="related-links" aria-labelledby="related-links-heading">
    <div class="related-heading">
      <p class="mono-label mono-label--red">KEEP EXPLORING</p>
      <h2 id="related-links-heading">{heading}</h2>
    </div>
    <ul class="related-list">
      {links.map((link) => (
        <li>
          <a href={link.href}>
            <span class="mono-label">{kindLabels[link.kind]}</span>
            <span class="link-label">{link.label}</span>
            <span aria-hidden="true">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related-links {
    margin-top: var(--space-block);
    padding-top: 28px;
    border-top: 1px solid var(--trace);
    display: grid;
    gap: 18px;
  }

  .related-heading {
    display: grid;
    gap: 10px;
  }

  .related-heading h2 {
    font-family: var(--display);
    font-size: var(--fs-h3);
    line-height: 1.15;
  }

  .related-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .related-list a {
    min-height: 68px;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto 1fr;
    gap: 4px 12px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid var(--trace);
    color: var(--ink);
    text-decoration: none;
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .related-list a:hover,
  .related-list a:focus-visible {
    border-color: var(--red);
    background: var(--pure);
  }

  .related-list .mono-label {
    grid-column: 1 / -1;
    color: var(--mid);
  }

  .link-label {
    font-family: var(--display);
    font-size: 1.05rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .related-list a { transition: none; }
  }
</style>
