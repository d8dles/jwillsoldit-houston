---
import { REGION_SHAPES, RINGS, SPOKES, WATER } from '../data/houston-map';

interface Props {
  regionId: string;
  areaName: string;
  dotX: number;
  dotY: number;
}

const { regionId, areaName, dotX, dotY } = Astro.props;
const region = REGION_SHAPES.find((r) => r.id === regionId);
// Keep the label from spilling past the right edge of the map.
const labelAnchor: 'start' | 'end' = dotX > 84 ? 'end' : 'start';
const labelDx = labelAnchor === 'end' ? -2.4 : 2.4;
const title = region
  ? `${areaName} — within ${region.name}, schematic locator`
  : `${areaName} — schematic locator`;
---

<figure class="locator-figure">
  <svg class="map" viewBox="0 0 120 100" role="img" aria-label={title} xmlns="http://www.w3.org/2000/svg">
    <title>{title}</title>

    <path class="water" d={WATER} />

    <g class="network">
      {RINGS.map((ring) => (
        <path class="ring" d={ring.path} />
      ))}
      {SPOKES.map((spoke) => (
        <path class="spoke" d={spoke.path} />
      ))}
    </g>

    <g class="regions">
      {REGION_SHAPES.map((r) => (
        <path class:list={['region-shape', { active: r.id === regionId }]} d={r.path} />
      ))}
    </g>

    <!-- Area pin -->
    <g class="pin">
      <circle class="pin-halo" cx={dotX} cy={dotY} r="2.6" />
      <circle class="pin-dot" cx={dotX} cy={dotY} r="1.3" />
      <text class="pin-label" x={dotX + labelDx} y={dotY + 0.9} text-anchor={labelAnchor}>{areaName}</text>
    </g>
  </svg>

  <figcaption class="map-caption">Schematic map — simplified for orientation, not survey-accurate.</figcaption>
</figure>

<style>
  .locator-figure {
    margin: 0;
    width: 100%;
    max-width: 340px;
    container-type: inline-size;
  }

  .map {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .water {
    fill: var(--forest);
    fill-opacity: 0.05;
  }

  .ring,
  .spoke {
    fill: none;
    stroke: var(--forest);
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
    opacity: 0.28;
  }
  .ring {
    stroke-width: 1;
  }
  .spoke {
    stroke-width: 0.8;
    opacity: 0.2;
  }

  .region-shape {
    fill: transparent;
    stroke: var(--trace);
    stroke-width: 0.6;
    vector-effect: non-scaling-stroke;
  }
  .region-shape.active {
    fill: var(--forest);
    fill-opacity: 0.08;
    stroke: var(--red);
    stroke-width: 1.1;
  }

  .pin-halo {
    fill: var(--red);
    opacity: 0.16;
  }
  .pin-dot {
    fill: var(--red);
  }
  .pin-label {
    font-family: var(--mono);
    font-size: 3.4px;
    font-weight: 700;
    letter-spacing: -0.01em;
    fill: var(--red-text);
    paint-order: stroke;
    stroke: var(--off-white);
    stroke-width: 1px;
    stroke-linejoin: round;
  }

  .map-caption {
    font-family: var(--mono);
    font-size: var(--fs-micro);
    color: var(--mid);
    margin-top: 10px;
    line-height: 1.4;
  }
</style>
